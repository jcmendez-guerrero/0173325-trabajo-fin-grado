@startuml 03-aws-public-layer-multiregion
' The content of this file has been partially generated by Antrophic Claude Sonnet 4.6 (2026) using GitHub Copilot and supervised by the author. 
' Some elements may have been modified or removed during the editing process.
' Public Layer Architecture - Wizzard's of the Coast
' Multi-region three-tier design - public layer only

' C4-PlantUML
!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Context.puml

' AWS Icons for PlantUML v23.0
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/AWSC4Integration.puml


' PlantUML Icon Font Sprites v3.0
!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v3.0.0/icons

' AWS groups
!include AWSPuml/Groups/AWSCloud.puml
!include AWSPuml/Groups/Region.puml
!include AWSPuml/Groups/VPC.puml
!include AWSPuml/Groups/PublicSubnet.puml
!include AWSPuml/Groups/PrivateSubnet.puml
!include AWSPuml/Groups/AvailabilityZone.puml
!include AWSPuml/Groups/GenericRed.puml
!include AWSPuml/Groups/CorporateDataCenter.puml

' AWS networking and public edge services
!include AWSPuml/NetworkingContentDelivery/CloudFront.puml
!include AWSPuml/NetworkingContentDelivery/GlobalAccelerator.puml
!include AWSPuml/NetworkingContentDelivery/ElasticLoadBalancingApplicationLoadBalancer.puml
!include AWSPuml/NetworkingContentDelivery/VPCNATGateway.puml
!include AWSPuml/NetworkingContentDelivery/VPCInternetGateway.puml
!include AWSPuml/NetworkingContentDelivery/PrivateLink.puml
!include AWSPuml/NetworkingContentDelivery/Route53.puml

' AWS security and storage
!include AWSPuml/SecurityIdentityCompliance/WAF.puml
!include AWSPuml/Storage/SimpleStorageServiceS3Standard.puml
!include AWSPuml/Storage/SimpleStorageServiceGeneralAccessPoints.puml

' AWS containers
!include AWSPuml/Containers/ElasticKubernetesService.puml

' AWS Compute
!include AWSPuml/Compute/Lambda.puml

' AWS Security and Compliance
!include AWSPuml/SecurityIdentityCompliance/Cognito.puml
!include AWSPuml/SecurityIdentityCompliance/CertificateManager.puml

' Generic Icons (on-prem elements)
!include ICONURL/font-awesome/shield.puml
!include ICONURL/font-awesome/server.puml
!include ICONURL/font-awesome/database.puml
!include ICONURL/font-awesome/globe.puml
!include ICONURL/material/router.puml
!include ICONURL/font-awesome/users.puml

LAYOUT_LEFT_RIGHT()

title AWS Public Layer Architecture\nMulti-Region Public Perimeter for a Three-Tier Design

AddRelTag("global_entry", $textColor="#0B5394", $lineColor="#0B5394", $lineStyle="bold", $legendText="Global inbound traffic")
AddRelTag("static_content", $textColor="#2E7D32", $lineColor="#2E7D32", $legendText="Static content delivery")
AddRelTag("regional_routing", $textColor="#7B1FA2", $lineColor="#7B1FA2", $lineStyle="bold", $legendText="Regional traffic distribution")
AddRelTag("public_to_private", $textColor="#C62828", $lineColor="#C62828", $legendText="Public to private application flow")
AddRelTag("controlled_egress", $textColor="#8D6E63", $lineColor="#8D6E63", $lineStyle="dashed", $legendText="Controlled outbound traffic")
AddRelTag("authentication", $textColor="#F57C00", $lineColor="#F57C00", $lineStyle="dashed", $legendText="Authentication flow")

AddPersonTag("nontrust", $sprite="users,color=red", $legendSprite="users,scale=0.25,color=red", $legendText="Non-Trusted User")
AddSystemTag("internet", $sprite="globe", $bgColor="red", $legendSprite="globe,scale=0.25", $legendText="Internet / Untrusted External System")
AddSystemTag("third_party", $sprite="robot", $bgColor="red", $legendSprite="robot,scale=0.25,color=red", $legendText="Third-party External System")

GenericRedGroup(externalusers, "Internet Area - Remote users & public services") {
    Person_Ext(client, "Internet Users", "Customers and public clients", $tags="nontrust")
    System_Ext(third_party, "Third-party Auth Services", "External services for authentication", $tags="third_party")
    System_Ext(partner, "Third-party Partners", "External partner systems consuming public APIs", $tags="third_party")

}

    System_Ext(internet, "Internet", "Global public network", $tags="internet")

CorporateDataCenterGroup(madrid, "Corp Data Center") {
    System_Ext(onpremauth, "On-prem Authentication", "Legacy authentication system first auth sync", $sprite="shield")
}

AWSCloudGroup(aws_public, "AWS Public Layer") {
    GlobalAccelerator(ga, "AWS Global Accelerator", "Global entry point", "Static anycast IPs and health-based regional routing")
    Route53(route53, "Amazon Route 53", "DNS service", "Global DNS") 
    CloudFront(cf, "Amazon CloudFront", "Global CDN", "Caches and serves static content close to end users")
    WAF(global_waf, "Amazon WAF", "Web application firewall", "Public perimeter protection for HTTP/S traffic")
    SimpleStorageServiceGeneralAccessPoints(s3_static_ga, "S3 Multi-Region Access Point", "Global static content access", "Unified endpoint for static content across regions")

    RegionGroup(region_eu, "Region 1 - eu-south-2") {
        SimpleStorageServiceS3Standard(s3_static, "Amazon S3 Bucket", "Static content origin", "Images, static pages and multimedia assets")
        VPCGroup(vpc_eu, "VPC DMZ - Europe") {
            VPCInternetGateway(igw_eu, "Internet Gateway EU", "VPC internet access", "Public ingress and controlled outbound path")

            PublicSubnetGroup(pub_eu, "Public Subnets az-a-b") {
                ElasticLoadBalancingApplicationLoadBalancer(alb_eu, "ALB EU Multi AZ", "Layer 7 entry", "TLS termination and HTTP routing")
                VPCNATGateway(nat_eu, "MultiZone NAT Gateway EU", "Outbound internet access", "Controlled egress for private workloads")
                Cognito(user_pool_eu, "Amazon Cognito User Pool", "User authentication and management", "Handles user sign-up, sign-in, and access control for EU region")
            }
        }
        VPCGroup(vpc_eu_priv, "VPC NON-DMZ - Europe") {



            AvailabilityZoneGroup(az_eu_1, "Availability Zone 1 - eu-south-2a") {
                Lambda(lambda_eu, "Lambda User Migration", "Serverless user migration function", "Handles user data migration from on-prem to Cognito")
                PrivateSubnetGroup(priv_eu_a, "Private/Internal Layers Cloud - AZ-a") {
                    System(eks_eu, "Compute Layer EU AZ-a", "Private compute layer\nBackend services consumed by the public layer")
                }
            }
            ' Resources in AZ-a
            AvailabilityZoneGroup(az_eu_2, "Availability Zone 2 - eu-south-2b") {

                PrivateSubnetGroup(priv_eu_b, "Private/Internal Layers Cloud - AZ-b") {
                    System(eks_eu_b, "Compute Layer EU AZ-b", "Private compute layer\nBackend services consumed by the public layer")
                }
            }
        }

    }

    RegionGroup(region_us, "Region 2 - us-east-1") {
        SimpleStorageServiceS3Standard(s3_static_us, "Amazon S3 Bucket", "Static content origin", "Images, static pages and multimedia assets")
        VPCGroup(vpc_us, "VPC DMZ - United States") {
            VPCInternetGateway(igw_us, "Internet Gateway US", "VPC internet access", "Public ingress and controlled outbound path")

            PublicSubnetGroup(pub_us, "Public Subnets az-a-b") {
                ElasticLoadBalancingApplicationLoadBalancer(alb_us, "ALB US Multi AZ", "Layer 7 entry", "TLS termination and HTTP routing")
                VPCNATGateway(nat_us, "MultiZone NAT Gateway US", "Outbound internet access", "Controlled egress for private workloads")
            }
        }
        VPCGroup(vpc_us_priv, "VPC NON-DMZ - United States") {
            AvailabilityZoneGroup(az_us_1, "Availability Zone 1 - us-east-1a") {
                PrivateSubnetGroup(priv_us_a, "Private/Internal Layers Cloud - AZ-a") {
                    System(eks_us, "Compute Layer US AZ-a", "Private compute layer\nBackend services consumed by the public layer")
                }
            }
            AvailabilityZoneGroup(az_us_2, "Availability Zone 2 - us-east-1b") {
                PrivateSubnetGroup(priv_us_b, "Private/Internal Layers Cloud - AZ-b") {
                    System(eks_us_b, "Compute Layer US AZ-b", "Private compute layer\nBackend services consumed by the public layer")
                }
            }
        }
    }
}

Rel(client, internet, "HTTPS requests")
Rel(client, route53, "DNS queries for public services", $tags="global_entry")
Rel(cf, route53, "GA dns queries for CDN", $tags="global_entry")
Rel(internet, cf, "Accelerated HTTP/S traffic", $tags="global_entry")
Rel(cf, ga, "Non-Cached HTTP/S traffic", $tags="global_entry")
Rel(cf, global_waf, "Filtered web traffic", $tags="global_entry")
Rel(cf, s3_static_ga, "Static content origin fetch", $tags="static_content")
Rel(s3_static_ga, s3_static, "Static content origin fetch", $tags="static_content")
Rel(s3_static_ga, s3_static_us, "Static content origin fetch", $tags="static_content")
Rel(s3_static, s3_static_us, "Cross-region replication", $tags="static_content")


Rel(ga, igw_eu, "Dynamic traffic to healthy EU endpoint", $tags="regional_routing")
Rel(igw_eu, alb_eu, "Dynamic traffic to healthy EU endpoint", $tags="regional_routing")

Rel(ga, igw_us, "Dynamic traffic to healthy US endpoint", $tags="regional_routing")
Rel(igw_us, alb_us, "Dynamic traffic to healthy US endpoint", $tags="regional_routing")

Rel_D(alb_eu, eks_eu, "Application traffic to private services", $tags="public_to_private")
Rel_D(alb_eu, eks_eu_b, "Application traffic to private services", $tags="public_to_private")
Rel_D(alb_us, eks_us, "Application traffic to private services", $tags="public_to_private")
Rel_D(alb_us, eks_us_b, "Application traffic to private services", $tags="public_to_private")

Rel_U(eks_eu, nat_eu, "Outbound updates and dependencies", $tags="controlled_egress")
Rel_U(eks_eu_b, nat_eu, "Outbound updates and dependencies", $tags="controlled_egress")
Rel_U(nat_eu, igw_eu, "Controlled internet egress", $tags="controlled_egress")
Rel_U(igw_eu, internet, "Outbound internet access", $tags="controlled_egress")

Rel_U(eks_us, nat_us, "Outbound updates and dependencies", $tags="controlled_egress")
Rel_U(eks_us_b, nat_us, "Outbound updates and dependencies", $tags="controlled_egress")
Rel_U(nat_us, igw_us, "Controlled internet egress", $tags="controlled_egress")
Rel_U(igw_us, internet, "Outbound internet access", $tags="controlled_egress")
Rel_U(internet, partner, "Partner API access", $tags="controlled_egress")
Rel_U(internet, partner, "Partner API access", $tags="controlled_egress")

' Authentication
Rel(cf,user_pool_eu, "User authentication for EU region", $tags="authentication")
Rel_U(user_pool_eu, third_party, "Social Auth", $tags="authentication")
BiRel_U(user_pool_eu, client, "User authentication", $tags="authentication")
BiRel(client, third_party, "Social Auth", $tags="authentication")
Rel(user_pool_eu, lambda_eu, "User migration trigger", $tags="authentication")
Rel(lambda_eu, onpremauth, "Fetch legacy user data", $tags="authentication")

SHOW_LEGEND()

@enduml
