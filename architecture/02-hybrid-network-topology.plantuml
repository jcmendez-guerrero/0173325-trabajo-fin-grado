@startuml 02-hybrid-network-topology
' The content of this file has been partially generated by Antrophic Claude Sonnet 4.6 (2026) using GitHub Copilot and supervised by the author. 
' Some elements may have been modified or removed during the editing process.

title Hybrid Network Topology - Wizzard's of the Coast\nAWS Multi-Region Hub-and-Spoke with Dual On-Premises Sites

' C4-PlantUML
!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Context.puml

' AWS Icons for PlantUML v23.0
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/AWSC4Integration.puml

' PlantUML Icon Font Sprites v3.0
!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v3.0.0/icons

' AWS Groups
!include AWSPuml/Groups/AWSCloud.puml
!include AWSPuml/Groups/Region.puml
!include AWSPuml/Groups/VPC.puml
!include AWSPuml/Groups/CorporateDataCenter.puml
!include AWSPuml/Groups/GenericGreen.puml
!include AWSPuml/Groups/GenericRed.puml

' AWS Networking Icons
!include AWSPuml/NetworkingContentDelivery/TransitGateway.puml
!include AWSPuml/NetworkingContentDelivery/SitetoSiteVPN.puml
!include AWSPuml/NetworkingContentDelivery/VPCInternetGateway.puml
!include AWSPuml/NetworkingContentDelivery/VPCVirtualprivatecloudVPC.puml
!include AWSPuml/NetworkingContentDelivery/VPCNATGateway.puml
!include AWSPuml/NetworkingContentDelivery/Route53.puml
!include AWSPuml/NetworkingContentDelivery/Route53Resolver.puml

' AWS Security Icons
!include AWSPuml/SecurityIdentityCompliance/NetworkFirewall.puml
!include AWSPuml/SecurityIdentityCompliance/WAF.puml

' Generic Icons (on-prem elements)
!include ICONURL/font-awesome/shield.puml
!include ICONURL/font-awesome/server.puml
!include ICONURL/font-awesome/database.puml
!include ICONURL/font-awesome/globe.puml
!include ICONURL/material/router.puml
!include ICONURL/font-awesome/users.puml

'  Open Architecture Elements
!define osaPuml https://raw.githubusercontent.com/Crashedmind/PlantUML-opensecurityarchitecture2-icons/master
!include osaPuml/Common.puml
!include osaPuml/User/all.puml

' ============================================================
' LAYOUT & STYLING
' ============================================================

LAYOUT_TOP_DOWN()

' Relationship tags for visual differentiation
AddRelTag("vpn_primary", $textColor="#2E7D32", $lineColor="#2E7D32", $lineStyle="bold", $legendText="VPN Primary (Madrid)")
AddRelTag("vpn_backup", $textColor="#F57C00", $lineColor="#F57C00", $lineStyle="dashed", $legendText="VPN Backup (A Coruña)")
AddRelTag("tgw_peering", $textColor="#7B1FA2", $lineColor="#7B1FA2", $lineStyle="bold", $legendText="TGW Inter-Region Peering")
AddRelTag("internet_flow", $textColor="#c01515", $lineColor="#c01515", $legendText="Internet / North-South")
AddRelTag("inspection", $textColor="#c68728", $lineColor="#c68728", $lineStyle="dashed", $legendText="Inspection Flow (AWS Network Firewall)")
AddRelTag("filtered", $textColor="#00838F", $lineColor="#00838F", $legendText="Filtered Traffic (WAF)", $lineStyle= SolidLine())
AddRelTag("onprem_traffic", $legendText="On-Premises Internal Traffic")
AddRelTag("egress_control", $textColor="#7d402e", $lineColor="#7d402e", $lineStyle="dashed", $legendText="Egress Controlled Traffic")
AddRelTag("dns_flow", $textColor="#2e5d7d", $lineColor="#2e5d7d", $lineStyle="dashed", $legendText="DNS Traffic")



AddPersonTag("nontrust", $sprite="users,color=red", $legendSprite="users,scale=0.25,color=red", $legendText="Non-Trusted User")
AddSystemTag("internet", $sprite="globe", $bgColor="red", $legendSprite="globe,scale=0.25", $legendText="Internet / Untrusted External System")

' ============================================================
' INTERNET
' ============================================================

System_Ext(internet, "Internet", "Public Internet / ISPs", $tags="internet") 
System_Ext(internet2, "Internet", "Public Internet / ISPs", $tags="internet")
System_Ext(internet3, "Internet", "Public Internet / ISPs", $tags="internet")
System_Ext(internet4, "Internet", "Public Internet / ISPs", $tags="internet")


GenericRedGroup(externalusers, "External Users - Remote users accessing public services") {
    Person_Ext(extuser, "External Users", "Users accessing public-facing services over the Internet", $tags="nontrust")
}

' ============================================================
' VPN: USERS & STORES
' ============================================================

GenericGreenGroup(vpn_users, "VPN Users - Remote users accessing AWS resources via VPN") {
    Person(user, "Users", "People that use VPN to access AWS resources", $sprite="users")
    note as n_usr
        10.1.0.0/21    VPN_USERS
    end note
}

GenericGreenGroup(vpn_stores, "VPN Stores - Remote stores accessing AWS resources via VPN") {
    Person(store, "Stores", "Stores that use VPN to access AWS resources", $sprite="users")
    note as n_store
        10.1.16.0/21    VPN_STORES
    end note
}

' ============================================================
' ON-PREMISES: MADRID - MAIN DATA CENTER
' ============================================================

CorporateDataCenterGroup(madrid, "Madrid - Main Data Center") {

    System(mad_fw, "Palo Alto HA Cluster", "Highly available perimeter firewall\nInternet egress + VPN tunnels to AWS\n(121.131.255.127)", $sprite="shield")
    System(mad_core, "Core Switche1", "Switching Core Stack", $sprite="server")
    System(mad_wl, "On-Prem Workloads", "AD/DNS · Billing · Internal databases\nAdministrative services · On-prem Kubernetes", $sprite="database")
    System(mad_router, "ISP 1 Router", "ISP Router 1\n(121.131.255.116)", $sprite="router")
    System(mad_router_2, "ISP 2 Router", "ISP Router 2\n(125.80.123.147)", $sprite="router")

    note as n_mad
        **Primary Networks - Madrid**
        ──────────────────────────────
        10.0.0.0/24    MANAGEMENT
        10.0.3.0/25    DMZ
        10.0.8.0/21    SERVERS NP
        10.0.16.0/21   SERVERS PROD
        10.0.24.0/21   SERVERS K8S
        10.0.32.0/19   PODS
        10.0.64.0/19   SERVICES
    end note
}

BiRel_U(mad_wl,mad_core, "", $tags="onprem_traffic")
BiRel_U(mad_core, mad_fw, "", $tags="onprem_traffic")
Rel_U(mad_fw, mad_router, "ISP 1", $tags="internet_flow")
Rel_U(mad_fw, mad_router_2, "ISP 2", $tags="internet_flow")
Rel_U(mad_router, internet3, "Internet Access", $tags="internet_flow")
Rel_U(mad_router_2, internet3, "Internet Access", $tags="internet_flow")

' ============================================================
' ON-PREMISES: A Coruña - SECONDARY DATA CENTER / DR
' ============================================================

CorporateDataCenterGroup(Coruña, "A Coruña - Secondary Data Center · Backup / DR") {
    System_Ext(CSP_LAN, "CSP LAN", "Internal colocation provider network", $sprite="globe")
    System(cor_fw, "Palo Alto", "Perimeter firewall\nBackup connection to AWS\n(153.233.122.30)", $sprite="shield")
    System(cor_core, "Core / ToR Switches", "Switching L3 / Top-of-Rack", $sprite="server")
    System(cor_wl, "DR Workloads", "Replicas · Backups · DR", $sprite="database")

    note as n_cor
        **Primary Networks - A Coruña**
        ──────────────────────────────────
        10.128.0.0/24    MANAGEMENT
        10.128.3.0/25    DMZ
        10.128.8.0/21    SERVERS
        10.128.16.0/21   SERVERS PROD
        10.128.24.0/21   SERVERS K8S
        10.128.32.0/19   PODS
        10.128.64.0/19   SERVICES
    end note

BiRel_U(cor_wl, cor_core, "", $tags="onprem_traffic")
BiRel_U(cor_core, cor_fw, "", $tags="onprem_traffic")
Rel_U(cor_fw, CSP_LAN, "Colocation Connection", $tags="internet_flow")
Rel_U(CSP_LAN, internet2, "Internet Access (153.233.122.50)", $tags="internet_flow")
}

' ============================================================
' AWS CLOUD
' ============================================================

AWSCloudGroup(aws_cloud) {

    ' ────────────────────────────────────────────────────────
    ' Global Services
    ' ────────────────────────────────────────────────────────

    Route53(route53, "Route 53", "DNS Service", "Domain name management and global DNS resolution")
    Route53Resolver(route53resolver, "Route 53 Resolver", "DNS Resolver", "Private DNS resolution for VPCs\nIntegrated with TGW for centralized resolution")

    ' ────────────────────────────────────────────────────────
    ' EU REGION - eu-south-2 (Primary Europe)
    ' ────────────────────────────────────────────────────────

    RegionGroup(region_eu, "eu-south-2 - AWS EU Region · Supernet 10.64.0.0/10") {

        ' Hub
        TransitGateway(tgw_eu, "TGW-EU", "Transit Gateway", "Central hub in eu-south-2\nAll VPCs attached as spokes")



        ' Spoke: VPC Ingress/Egress
        VPCGroup(vpc_ie_eu, "VPC Ingress/Egress EU - 10.68.0.0/24 (Infra OU)") {
            VPCInternetGateway(igw_eu, "IGW EU", "Internet Gateway", "Internet ingress/egress")
            VPCNATGateway(nat_eu, "NAT GW EU", "NAT Gateway", "Controlled egress from private VPCs")
        ' Security: WAF
        WAF(waf_eu, "AWS WAF EU", "Web Application Firewall", "Public web layer protection\n(ALB / CloudFront / Route 53)")
        }

        ' Spoke: VPC Inspection
        VPCGroup(vpc_insp_eu, "VPC Inspection EU - 10.70.0.0/24 (Security OU)") {
            NetworkFirewall(nfw_eu, "AWS Network Firewall EU", "Network Firewall", "Centralized L3-L7 inspection\nIntegrated with TGW")
        }

        ' Spoke VPCs (standalone elements)
        VPCVirtualprivatecloudVPC(vpc_other_eu, "Other VPC EU", "Other Assigned VPC Networks", "")


        ' IP Pools per OU: Europe
        note as n_pools_eu #EEEEEE
            **IP Pools by OU - Europe (eu-south-2)**
            ═══════════════════════════════════════════
            10.64.0.0/16  → **OU PROD EU**
            10.66.0.0/16  → **OU NONPROD EU**
            10.68.0.0/16  → **OU INFRA EU**
            10.70.0.0/16  → **OU SECURITY EU**
            10.72.0.0/16  → **OU SANDBOX EU**
            ───────────────────────────────────────────
            Actual VPC CIDRs are allocated as **/24**
            from these /16 pools.

            **Kubernetes - Overlay Ranges**
            ════════════════════════════════════
            **EU:** 10.127.0.0/16
            ────────────────────────────────────
        end note




    }
    ' ────────────────────────────────────────────────────────
    ' US REGION - us-east-1 (Primary US)
    ' ────────────────────────────────────────────────────────

    RegionGroup(region_us, "us-east-1 - AWS US Region · Supernet 10.192.0.0/10") {

        ' Hub
        TransitGateway(tgw_us, "TGW-US", "Transit Gateway", "Central hub in us-east-1\nAll VPCs attached as spokes")

 

        ' Spoke: VPC Ingress/Egress
        VPCGroup(vpc_ie_us, "VPC Ingress/Egress US - 10.196.0.0/24 (Infra OU)") {
            VPCInternetGateway(igw_us, "IGW US", "Internet Gateway", "Internet ingress/egress")
            VPCNATGateway(nat_us, "NAT GW US", "NAT Gateway", "Controlled egress from private VPCs")
        ' Security: WAF
            WAF(waf_us, "AWS WAF US", "Web Application Firewall", "Public web layer protection\n(ALB / CloudFront / Route 53)")
        }

        ' Spoke: VPC Inspection
        VPCGroup(vpc_insp_us, "VPC Inspection US - 10.198.0.0/24 (Security OU)") {
            NetworkFirewall(nfw_us, "AWS Network Firewall US", "Network Firewall", "Centralized L3-L7 inspection\nIntegrated with TGW")
        }

        ' Spoke VPCs (standalone elements)
        VPCVirtualprivatecloudVPC(vpc_other_us, "Other VPC US", "Other Assigned VPC Networks", "")

        ' IP Pools per OU: US
        note as n_pools_us #EEEEEE
            **IP Pools by OU - U.S. (us-east-1)**
            ═══════════════════════════════════════════
            10.192.0.0/16 → **OU PROD US**
            10.194.0.0/16 → **OU NONPROD US**
            10.196.0.0/16 → **OU INFRA US**
            10.198.0.0/16 → **OU SECURITY US**
            10.200.0.0/16 → **OU SANDBOX US**
            ───────────────────────────────────────────
            Actual VPC CIDRs are allocated as **/24**
            from these /16 pools.

            **Kubernetes - Overlay Ranges**
            ════════════════════════════════════
            **US:** 10.255.0.0/16
            ────────────────────────────────────
        end note
    }
}


' ============================================================
' RELATIONSHIPS: NORTH-SOUTH (Internet)
' ============================================================

Rel_D(internet, waf_eu, "HTTPS", $tags="internet_flow")
Rel_D(internet, waf_us, "HTTPS", $tags="internet_flow")



Rel_R(vpc_other_eu, tgw_eu, "VPC egress traffic", $tags="egress_control")
Rel(tgw_eu, nfw_eu, "VPC egress inspection traffic", $tags="egress_control")
Rel_U(tgw_eu, nat_eu, "Controlled egress traffic", $tags="egress_control")
Rel_U(nat_eu, igw_eu, "Controlled internet egress", $tags="egress_control")
Rel_U(igw_eu, internet, "Egress Internet Access", $tags="egress_control")
Rel_L(vpc_other_us, tgw_us, "VPC egress traffic", $tags="egress_control")
Rel(tgw_us, nfw_us, "VPC egress inspection traffic", $tags="egress_control")
Rel_U(tgw_us, nat_us, "Controlled egress traffic", $tags="egress_control")
Rel_U(nat_us, igw_us, "Controlled internet egress", $tags="egress_control")
Rel_U(igw_us, internet, "Egress Internet Access", $tags="egress_control")


BiRel(extuser, internet, "Access to public services\n(Portals, public APIs, etc.)", $tags="internet_flow")

' ============================================================
' RELATIONSHIPS: HYBRID CONNECTIVITY (VPN Site-to-Site)
' ============================================================

' Madrid - Primary VPN connections to both TGWs
BiRel_R(mad_fw, tgw_eu, "VPN Site-to-Site\n(Primary EU)", $tags="vpn_primary")
BiRel_R(mad_fw, tgw_us, "VPN Site-to-Site\n(Primary US)", $tags="vpn_primary")

' A Coruña - Backup VPN connections to both TGWs
BiRel_L(cor_fw, tgw_eu, "VPN Site-to-Site\n(Backup EU)", $tags="vpn_backup")

'  S2S VPN for both CPDs
BiRel_R(mad_fw, cor_fw, "VPN Site-to-Site\n(Primary EU)", $tags="vpn_primary")


' ============================================================
' RELATIONSHIPS: VPN CONNECTIVITY (VPN User-to-Site)
' ============================================================

BiRel(user, mad_fw, "VPN Client", $tags="vpn_primary")
Lay_D(user,store)
BiRel(store, mad_fw, "VPN Client", $tags="vpn_primary")

' ============================================================
' RELATIONSHIPS: INTER-REGION PEERING
' ============================================================

BiRel_R(tgw_eu, tgw_us, "TGW Inter-Region Peering\neu-south-2 ↔ us-east-1", $tags="tgw_peering")

' ============================================================
' RELATIONSHIPS: INSPECTION FLOW (All Traffic from TGW to Network Firewall)
' ============================================================

BiRel(vpc_other_eu, tgw_eu, "Regular traffic", $tags="inspection")
BiRel(tgw_eu, nfw_eu, "Regular traffic", $tags="inspection")
BiRel(vpc_other_us, tgw_us, "Regular traffic", $tags="inspection")
BiRel(tgw_us, nfw_us, "Regular traffic", $tags="inspection")


' ============================================================
' RELATIONSHIPS: DNS TRAFFIC (Route 53)
' ============================================================

Rel(vpc_other_eu, route53resolver, "DNS Query", $tags="dns_flow")
Rel(vpc_other_us, route53resolver, "DNS Query", $tags="dns_flow")
Rel(route53resolver, route53, "DNS Query Forwarding", $tags="dns_flow")
BiRel(route53, internet4, "DNS Query Forwarding", $tags="dns_flow")
BiRel_L(route53resolver, mad_fw, "DNS Query Forwarding", $tags="dns_flow")
BiRel_R(route53resolver, cor_fw, "DNS Query Forwarding", $tags="dns_flow")


' ============================================================
' AUTO-GENERATED LEGEND (from relationship tags)
' ============================================================

SHOW_LEGEND()

@enduml
