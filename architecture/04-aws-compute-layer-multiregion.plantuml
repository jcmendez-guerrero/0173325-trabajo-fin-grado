@startuml 04-aws-compute-layer-multiregion
' The content of this file has been partially generated by Antrophic Claude Sonnet 4.6 (2026) using GitHub Copilot and supervised by the author. 
' Some elements may have been modified or removed during the editing process.
' Compute Layer Architecture - Wizzard's of the Coast
' Multi-region three-tier design - compute layer focus
' Validates test R02F06T01P02

' C4-PlantUML
!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Context.puml

' AWS Icons for PlantUML v23.0
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/AWSC4Integration.puml

' Kubernetes icons
!define KubernetesPuml https://raw.githubusercontent.com/dcasati/kubernetes-PlantUML/master/dist
!includeurl KubernetesPuml/kubernetes_Common.puml
' !includeurl KubernetesPuml/kubernetes_Context.puml
' !includeurl KubernetesPuml/kubernetes_Simplified.puml
!includeurl KubernetesPuml/OSS/KubernetesApi.puml
!includeurl KubernetesPuml/OSS/KubernetesIng.puml
!includeurl KubernetesPuml/OSS/KubernetesSvc.puml
!includeurl KubernetesPuml/OSS/KubernetesPod.puml
!includeurl KubernetesPuml/OSS/KubernetesSa.puml

' PlantUML Icon Font Sprites v3.0
!define ICONURL https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/v3.0.0/icons

' AWS Groups
!include AWSPuml/Groups/AWSCloud.puml
!include AWSPuml/Groups/Region.puml
!include AWSPuml/Groups/VPC.puml
!include AWSPuml/Groups/PublicSubnet.puml
!include AWSPuml/Groups/PrivateSubnet.puml
!include AWSPuml/Groups/AvailabilityZone.puml
!include AWSPuml/Groups/GenericGreen.puml
!include AWSPuml/Groups/GenericPurple.puml

' AWS Services - Networking
!include AWSPuml/NetworkingContentDelivery/GlobalAccelerator.puml
!include AWSPuml/NetworkingContentDelivery/ElasticLoadBalancingApplicationLoadBalancer.puml
!include AWSPuml/NetworkingContentDelivery/ElasticLoadBalancingNetworkLoadBalancer.puml
!include AWSPuml/NetworkingContentDelivery/VPCNATGateway.puml

' AWS Services - Containers
!include AWSPuml/Containers/ElasticContainerRegistry.puml
!include AWSPuml/Containers/ElasticKubernetesService.puml

' AWS Services - Security
!include AWSPuml/SecurityIdentityCompliance/IdentityandAccessManagement.puml
!include AWSPuml/SecurityIdentityCompliance/SecretsManager.puml

' AWS Services - Compute
!include AWSPuml/Compute/EC2.puml

' Generic Icons
!include ICONURL/font-awesome/database.puml

LAYOUT_LEFT_RIGHT()

title AWS Compute Layer Architecture\nActive-Active Multi-Region EKS\n(R02F06T01P02)

AddRelTag("ingress", $textColor="#0B5394", $lineColor="#0B5394", $lineStyle="bold", $legendText="Ingress traffic (Public Layer -> Compute)")
AddRelTag("k8s_internal", $textColor="#2E7D32", $lineColor="#2E7D32", $legendText="Kubernetes internal traffic")
AddRelTag("orchestration", $textColor="#607D8B", $lineColor="#607D8B", $lineStyle="dashed", $legendText="Control plane orchestration")
AddRelTag("security", $textColor="#F57C00", $lineColor="#F57C00", $lineStyle="dashed", $legendText="IAM / IRSA identity binding")
AddRelTag("secrets_sync", $textColor="#1f21a2", $lineColor="#1f21a2", $lineStyle="dashed", $legendText="Secrets Consumption and Sync")
AddRelTag("image_pull", $textColor="#7B1FA2", $lineColor="#7B1FA2", $legendText="Container image pull (ECR)")
AddRelTag("data_flow", $textColor="#28c630", $lineColor="#28c630", $lineStyle="bold", $legendText="Secure traffic to persistence layer (TLS)")
AddRelTag("egress", $textColor="#d10202", $lineColor="#d10202", $lineStyle="dashed", $legendText="Egress traffic (Compute -> Public Layer or external)")



AWSCloudGroup(aws_cloud, "AWS Cloud") {
    GenericGreenGroup(public_layer, "Public Layer") {
        System(public, "Public Services", "Pablic layer ALB / NatGW", $sprite="cloud")
    }

    GenericPurpleGroup(shared_svc, "Shared AWS Services (inside AWS)") {
        ElasticContainerRegistry(ecr, "Amazon ECR", "Corporate image registry", "Centralized and managed container image repository")
        IdentityandAccessManagement(iam_svc, "AWS IAM", "Identity & Access Management", "IRSA federation endpoint for least-privilege pod access")
    }

    GenericPurpleGroup(persistence_layer, "Persistence Layer") {
        System(persistence, "Persistence Services", "RDS / ElastiCache / storage backends", $sprite="database")
    }

    RegionGroup(region_eu, "eu-south-2 (Active)") {
        VPCGroup(vpc_aws_eu, "VPC - AWS)") {
            ElasticKubernetesService(cp_eu, "EKS Control Plane EU", "AWS-managed control plane outside VPC")
        }
        VPCGroup(vpc_eu, "VPC - Compute Domain (EU)") {


            PrivateSubnetGroup(priv_eu, "Private Subnets (EKS data plane)") {
                ElasticLoadBalancingNetworkLoadBalancer(nlb_eu, "NLB EU", "Regional service exposure", "Created by the ingress service so ALB can reach NGINX")
                SecretsManager(secrets_mgr_eu, "AWS Secrets Manager", "Secrets management", "Centralized and managed secrets repository")

                AvailabilityZoneGroup(az_eu_a, "AZ eu-south-2a") {
                    EC2(ng_eu_a, "EKS Worker Nodes AZ-a", "m7i.2xlarge", "Kubernetes worker nodes") {
                        KubernetesIng(nginx_eu, "NGINX Ingress Controller", "controller-operator")
                        KubernetesSvc(svc_eu_a, "Kubernetes Services", "service")
                        KubernetesPod(pods_eu_a, "Microservices Pods AZ-a", "pod")
                        KubernetesSa(sa_eu, "Service Accounts", "serviceaccount")
                    }
                }

                AvailabilityZoneGroup(az_eu_b, "AZ eu-south-2b") {
                    EC2(ng_eu_b, "EKS Worker Nodes AZ-b", "m7i.2xlarge", "Kubernetes worker nodes") {
                        KubernetesSvc(svc_eu_b, "Kubernetes Services", "service")
                        KubernetesPod(pods_eu_b, "Microservices Pods AZ-b", "pod")
                    }
                }
            }
        }
    }

    RegionGroup(region_us, "us-east-1 (Active)") {
        note as active_note
            **Active-Active Design**
            No interregional microservice traffic.
            Each region serves requests locally
            and independently.
        end note
        ElasticKubernetesService(cp_us, "EKS Control Plane US", "AWS-managed control plane outside VPC")

        VPCGroup(vpc_us, "VPC - Compute Domain (US)") {

            PrivateSubnetGroup(priv_us, "Private Subnets (EKS data plane)") {
                ElasticLoadBalancingNetworkLoadBalancer(nlb_us, "NLB US", "Regional service exposure", "Created by the ingress service so ALB can reach NGINX")
                SecretsManager(secrets_mgr_us, "AWS Secrets Manager", "Secrets management", "Centralized and managed secrets repository")
                AvailabilityZoneGroup(az_us_a, "AZ us-east-1a") {
                    EC2(ng_us_a, "EKS Worker Nodes AZ-a", "m7i.2xlarge", "Kubernetes worker nodes") {
                        KubernetesIng(nginx_us, "NGINX Ingress Controller", "controller-operator")
                        KubernetesSvc(svc_us_a, "Kubernetes Services", "service")
                        KubernetesPod(pods_us_a, "Microservices Pods AZ-a", "pod")
                        KubernetesSa(sa_us, "Service Accounts", "serviceaccount")
                    }
                }

                AvailabilityZoneGroup(az_us_b, "AZ us-east-1b") {
                    EC2(ng_us_b, "EKS Worker Nodes AZ-b", "m7i.2xlarge", "Kubernetes worker nodes") {
                        KubernetesSvc(svc_us_b, "Kubernetes Services", "service")
                        KubernetesPod(pods_us_b, "Microservices Pods AZ-b", "pod")
                    }
                }
            }
        }
    }
}


Rel(public, nlb_eu, "Forward traffic to discoverable NGINX endpoint", $tags="ingress")
Rel(nlb_eu, nginx_eu, "TCP/HTTP traffic to ingress controller", $tags="ingress")
Rel(nginx_eu, svc_eu_a, "Route by host/path", $tags="k8s_internal")
Rel(nginx_eu, svc_eu_b, "Route by host/path", $tags="k8s_internal")
Rel(svc_eu_a, pods_eu_a, "Service-to-pod", $tags="k8s_internal")
Rel(svc_eu_b, pods_eu_b, "Service-to-pod", $tags="k8s_internal")

Rel(pods_eu_a, sa_eu, "Runs with", $tags="security")
Rel(sa_eu, iam_svc, "Assume role via IRSA", $tags="security")
Rel(ng_eu_a, ecr, "Pull images", $tags="image_pull")
Rel(ng_eu_b, ecr, "Pull images", $tags="image_pull")
Rel(pods_eu_a, persistence, "Secure data access (TLS)", $tags="data_flow")
Rel(pods_eu_b, persistence, "Secure data access (TLS)", $tags="data_flow")

Rel(public, nlb_us, "Forward traffic to discoverable NGINX endpoint", $tags="ingress")
Rel(nlb_us, nginx_us, "TCP/HTTP traffic to ingress controller", $tags="ingress")
Rel(nginx_us, svc_us_a, "Route by host/path", $tags="k8s_internal")
Rel(nginx_us, svc_us_b, "Route by host/path", $tags="k8s_internal")
Rel(svc_us_a, pods_us_a, "Service-to-pod", $tags="k8s_internal")
Rel(svc_us_b, pods_us_b, "Service-to-pod", $tags="k8s_internal")

Rel(pods_us_a, sa_us, "Runs with", $tags="security")
Rel(sa_us, iam_svc, "Assume role via IRSA", $tags="security")
Rel(ng_us_a, ecr, "Pull images", $tags="image_pull")
Rel(ng_us_b, ecr, "Pull images", $tags="image_pull")
Rel(pods_us_a, persistence, "Secure data access (TLS)", $tags="data_flow")
Rel(pods_us_b, persistence, "Secure data access (TLS)", $tags="data_flow")

BiRel(secrets_mgr_eu, secrets_mgr_us, "Secrets sync", $tags="secrets_sync")
Rel_U(pods_eu_b, secrets_mgr_eu, "Secrets retrieval", $tags="secrets_sync")
Rel_L(pods_us_a, secrets_mgr_us, "Secrets retrieval", $tags="secrets_sync")

Rel_U(pods_eu_b, public, "Egress traffic (e.g. external APIs)", $tags="egress")
Rel(pods_us_a, public, "Egress traffic (e.g. external APIs)", $tags="egress")




SHOW_LEGEND()

@enduml
