@startuml 05-aws-data-layer-multiregion
' The content of this file has been partially generated by Antrophic Claude Sonnet 4.6 (2026) using GitHub Copilot and supervised by the author.
' Some elements may have been modified or removed during the editing process.
' Data Layer Architecture - Wizzard's of the Coast
' Multi-region three-tier design - persistence layer focus

' C4-PlantUML
!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Context.puml
!includeurl C4Puml/C4_Container.puml

' AWS Icons for PlantUML v23.0
!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v23.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/AWSC4Integration.puml

' AWS groups
!include AWSPuml/Groups/AWSCloud.puml
!include AWSPuml/Groups/Region.puml
!include AWSPuml/Groups/VPC.puml
!include AWSPuml/Groups/PrivateSubnet.puml
!include AWSPuml/Groups/AvailabilityZone.puml
!include AWSPuml/Groups/GenericGreen.puml
!include AWSPuml/Groups/GenericPurple.puml

' AWS networking
!include AWSPuml/NetworkingContentDelivery/VPCEndpoints.puml
!include AWSPuml/NetworkingContentDelivery/ClientVPN.puml

' AWS database and cache
!include AWSPuml/Database/RDS.puml
!include AWSPuml/Database/ElastiCache.puml

' AWS storage
!include AWSPuml/Storage/SimpleStorageServiceS3IntelligentTiering.puml
!include AWSPuml/Storage/ElasticBlockStore.puml
!include AWSPuml/Storage/ElasticFileSystemFileSystem.puml

' AWS security
!include AWSPuml/SecurityIdentityCompliance/KeyManagementService.puml
!include AWSPuml/SecurityIdentityCompliance/IdentityandAccessManagement.puml

LAYOUT_TOP_DOWN()

title AWS Data Layer Architecture\nRestricted Multi-Region Persistence Plane for a Three-Tier Design

AddRelTag("non_pii_data_flow", $textColor="#C62828", $lineColor="#C62828", $lineStyle="bold", $legendText="Transactional Reads/Writes (non-PII)")
AddRelTag("pii_data_flow", $textColor="#0B5394", $lineColor="#0B5394", $legendText="Transactional Reads/Writes (PII)")
AddRelTag("sync_replication", $textColor="#6A1B9A", $lineColor="#6A1B9A", $lineStyle="bold", $legendText="Synchronous replication / failover")
AddRelTag("async_replication", $textColor="#8E24AA", $lineColor="#8E24AA", $lineStyle="dashed", $legendText="Asynchronous cross-region replication")
AddRelTag("cache_flow", $textColor="#2E7D32", $lineColor="#2E7D32", $legendText="Cache access")
AddRelTag("object_flow", $textColor="#1565C0", $lineColor="#1565C0", $lineStyle="dashed", $legendText="Private object access via endpoint")
AddRelTag("persistent_storage", $textColor="#8D6E63", $lineColor="#8D6E63", $legendText="Persistent container storage")
AddRelTag("admin_vpn", $textColor="#455A64", $lineColor="#455A64", $lineStyle="bold", $legendText="Administration via VPN only")
AddRelTag("access_control", $textColor="#37474F", $lineColor="#37474F", $lineStyle="dashed", $legendText="Security Groups / IAM Roles / logical isolation")


AWSCloudGroup(aws_data, "AWS") {

    GenericPurpleGroup(security_controls, "Security, Access and Encryption") {
        KeyManagementService(kms_cmk, "AWS KMS CMK", "Customer-managed keys", "Encryption at rest for RDS, ElastiCache, S3, EBS and EFS")
        note as kms_note #ffff00
            KMS CMK is used for encryption at rest across all data services.
            Ensures data is encrypted with keys under our control.
            Key policies restrict access to authorized roles only.
        end note
    }

    RegionGroup(region_primary, "Primary Region - eu-south-2 (Europe)") {
        GenericGreenGroup(compute_summary, "Compute Layer (summarized) - EU") {
            System_Boundary(eks_eu, "Private EKS EU", "Primary-region application pods using IAM Roles") {
                Container(domains_shared, "Marketplace | Inventory | Catalog | Reporting | Authentication and Notifications | Frontend", "Logical schemas / functional domains")
                Container(domains_clients, "Clients", "EU-only regulated schema / functional domain")
            }
        }
        VPCGroup(vpc_data_eu, "Data VPC - Europe") {
            AvailabilityZoneGroup(az_eu_a, "Availability Zone 1 - eu-south-2a") {
                PrivateSubnetGroup(priv_rel_eu_a, "Private Relational Subnet AZ-a") {
                    RDS(rds_pg_primary, "Amazon RDS for PostgreSQL - Primary", "Writer", "Main transactional relational database")
                    RDS(rds_pii_primary, "Amazon RDS for PostgreSQL - Personal Data Primary", "Writer", "EU-only regulated personal data database")
                }
            }

            AvailabilityZoneGroup(az_eu_b, "Availability Zone 2 - eu-south-2b") {
                PrivateSubnetGroup(priv_rel_eu_b, "Private Relational Subnet AZ-b") {
                    RDS(rds_pg_standby, "Amazon RDS for PostgreSQL - Standby", "Synchronous standby", "Automatic failover target inside the same region")
                    RDS(rds_pii_standby, "Personal Data Standby", "Synchronous standby", "Compliance-preserving standby inside the EU only")
                }
            }

            PrivateSubnetGroup(priv_cache_eu, "Private Cache Subnet") {
                ElastiCache(redis_eu, "Amazon ElastiCache", "Active in-memory cache", "Authentication sessions and frequently accessed data")
            }

            PrivateSubnetGroup(priv_object_eu, "Private Object and Container Storage") {
                VPCEndpoints(s3_ep_eu, "S3 Gateway Endpoint", "Private VPC access", "Private route from VPC to S3 with no Internet path")
                SimpleStorageServiceS3IntelligentTiering(s3_general_eu, "Amazon S3 - General Use", "Object storage", "General unstructured data with Intelligent-Tiering")
                ElasticBlockStore(ebs_eu, "Amazon EBS", "High-performance CSI volumes", "Persistent block storage for stateful high-performance containers")
                ElasticFileSystemFileSystem(efs_eu, "Amazon EFS", "Shared filesystem", "General shared storage for multi-pod access")
            }

        }

    }

    RegionGroup(region_secondary, "Secondary Region - us-east-1") {
        GenericGreenGroup(compute_summary_us, "Compute Layer (summarized) - US") {
            System_Boundary(eks_us, "Private EKS US", "Secondary-region application pods and read-oriented workloads") {
                Container(domains_shared_us, "Marketplace | Inventory | Catalog | Reporting | Authentication and Notifications | Frontend", "Logical schemas / functional domains")
                Container(domains_clients_us, "Clients", "EU-only regulated schema / functional domain")
            }
        }
        VPCGroup(vpc_data_us, "Data VPC - United States") {

            AvailabilityZoneGroup(az_us_a, "Availability Zone 1 - us-east-1a") {
                PrivateSubnetGroup(priv_rel_us_a, "Private Relational Subnet AZ-a") {
                    RDS(rds_pg_rr_us, "Amazon RDS for PostgreSQL - Read Replica", "Asynchronous read replica", "Read-only replica for secondary region")
                }
            }

            PrivateSubnetGroup(priv_cache_us, "Private Cache Subnet") {
                ElastiCache(redis_us, "Amazon ElastiCache", "Passive replica", "Promoted only during regional failover")
            }

            PrivateSubnetGroup(priv_object_us, "Private Object and Container Storage") {
                VPCEndpoints(s3_ep_us, "S3 Gateway Endpoint", "Private VPC access", "Private route from VPC to S3 with no Internet path")
                SimpleStorageServiceS3IntelligentTiering(s3_general_us, "Amazon S3 - General Use", "Object storage", "Regional copy for unstructured data with Intelligent-Tiering")
                ElasticBlockStore(ebs_us, "Amazon EBS", "High-performance CSI volumes", "Persistent block storage for stateful high-performance containers")
                ElasticFileSystemFileSystem(efs_us, "Amazon EFS", "Shared filesystem", "General shared storage for multi-pod access")
            }
        }

    }
}

Rel(domains_shared, rds_pg_primary, "Transactional R/W", $tags="non_pii_data_flow")
Rel(domains_clients, rds_pii_primary, "Personal-data R/W", $tags="non_pii_data_flow")
Rel(domains_clients_us, rds_pii_primary, "Personal-data R/W", $tags="pii_data_flow")
Rel(domains_shared_us, rds_pg_rr_us, "Regional reads from replica", $tags="pii_data_flow")
Rel(domains_shared_us, rds_pg_primary, "Transactional Writes or Strongly consistent reads", $tags="non_pii_data_flow")

Rel(rds_pg_primary, rds_pg_standby, "Synchronous Multi-AZ replication", $tags="sync_replication")
Rel(rds_pii_primary, rds_pii_standby, "Synchronous Multi-AZ replication", $tags="sync_replication")
Rel_R(rds_pg_primary, rds_pg_rr_us, "Asynchronous cross-region read replication", $tags="async_replication")

Rel(domains_shared, redis_eu, "Auth cache and hot-data lookups", $tags="cache_flow")
Rel(domains_shared_us, redis_us, "Auth cache and hot-data lookups", $tags="cache_flow")
Rel_R(redis_eu, redis_us, "Active-passive cache replication", $tags="async_replication")

Rel(eks_eu, s3_ep_eu, "Private object access", $tags="object_flow")
Rel(s3_ep_eu, s3_general_eu, "Gateway endpoint route", $tags="object_flow")
Rel(eks_us, s3_ep_us, "Private object access", $tags="object_flow")
Rel(s3_ep_us, s3_general_us, "Gateway endpoint route", $tags="object_flow")

Rel(eks_eu, ebs_eu, "CSI block volumes for stateful pods", $tags="persistent_storage")
Rel(eks_eu, efs_eu, "Shared filesystem mounts", $tags="persistent_storage")
Rel(eks_us, ebs_us, "CSI block volumes for stateful pods", $tags="persistent_storage")
Rel(eks_us, efs_us, "Shared filesystem mounts", $tags="persistent_storage")

Lay_D(rds_pg_rr_us,redis_us)
Lay_L(rds_pg_primary, rds_pii_primary)

SHOW_LEGEND()

@enduml